<!-- MARC FIX THIS -->
<style>
main {
	position: absolute;
	top: var(--space-56);
	left: 0;
	width: 100%;
	height: 100%;
	padding: 0 !important;
}
iframe {
	width: 100%;
	height: 100%;
}
</style>

<%
if params.id then
	local url = ngx.var.scheme .. '://' .. ngx.var.host .. ':' ..
		ngx.var.server_port .. '/project/' .. params.id
%>
<iframe src="/snap/snap.html#open:<%= url %>"></iframe>
<% else %>
<iframe src="/snap/snap.html"></iframe>
<% end %>
