<header class="v-user__header u-padding-x">
	<div class="v-user__header-type"><%= locale.get('title_' .. account_type .. '_account') %></div>
	<h1 class="v-user__header-name"><%- current_user.username %></h1>
</header>

<% if not current_user.is_teacher then %>
<div class="u-padding-x">
	<div class="v-user__puzzles">

		<div class="v-user__puzzles-heading">
			<% render('frontend.views.partials.section-heading-full-width', {
				title	= locale.get('title_student_puzzles'),
				link	= {
					label	= 'Add Puzzle',
					url	 	= '#',
					color	= 'yellow',
					icon	= 'plus',
				}
			}) %>
		</div>

		<div class="v-user__puzzles-grid">
			<% render('frontend.views.partials.puzzles-grid', {
				puzzles = my_puzzles
			}) %>
		</div>

	</div>
</div>
<% end %>

<% if current_user.is_teacher then %>
<div class="u-padding-x">

	<section class="v-user__puzzles">

		<div class="v-user__puzzles-heading">
			<% render('frontend.views.partials.section-heading-full-width', {
				title = locale.get('title_my_classes')
			}) %>
		</div>

		<%
		render(
			'frontend.views.partials.classes-grid',
			{
				classes = package.loaded.Collections:select(
					package.loaded.db.clause({ creator_id = current_user.id })
				)
			}
		)
		%>

	<section>

	<section class="v-user__create">
		<script src="/static/js/papaparse.min.js"></script>
		<div class="v-user__options-heading">
			<% render('frontend.views.partials.section-heading-full-width', {
				title = locale.get('title_create_accounts')
			}) %>
		</div>

		<div class="v-user__options-contents">

			<div class="v-user__options-column">
				<div class="v-user__options-block">
					<h3 class="v-user__options-block-title"><%= locale.get('title_bulk_creation') %></h3>
					<div class="v-user__options-block-contents markdown">
						<%
							render(
								'frontend.views.partials.markdown',
								{ content = locale.get('md_provide_csv') }
							)
						%>
						<div class="--code">
							username,password<br>
							johndoe_240,xajglasibkasx<br>
							janedoe_784,hkjasd895mdas
						</div>
					</div>
				</div>
			</div>

			<div class="v-user__options-column">
				<div class="v-user__options-block">
					<h3 class="v-user__options-block-title"><%= locale.get('title_upload_csv') %></h3>
					<div class="v-user__options-block-contents">
						<form enctype="multipart/form-data" onsubmit="return false;">
							<input type="file"
								class="form-control csv"
								placeholder=""
								aria-label="Upload a CSV File"
								aria-describedby="button-addon1"
								name="csv"
							>
							<p><b><%= locale.get('text_paste_csv') %></b></p>
							<textarea id="students" name="students" rows="10" placeholder="username,password"></textarea>
							<label class="e-label__checkbox create_class">
								<input type="checkbox" name="create-class" value="1">
								<div class="e-label__text"><%= locale.get('text_create_class') %></div>
							</label>
							<input
								type="text"
								name="class-name"
								placeholder="<%= current_user.username .. ' klass ' .. os.date('*t').year%>"
							>
							<button name="bulk-create" type="submit">
								<div class="e-submit__text"><%= locale.get('b_create_users') %></div>
								<div class="e-submit__icon">
									<% render('frontend.static.svg.icon-arrow-right--24x24') %>
								</div>
							</button>
						</form>
					</div>
				</div>
			</div>

			<script type="text/javascript">
				var div = document.querySelector('.v-user__create');
				let create_learners = function(e) {
					var collection_name =
						div.querySelector('input[name="create-class"]').checked ?
							div.querySelector('input[name="class-name"]').value :
							null,
					file = div.querySelector('.csv').files[0],
					csv_text = div.querySelector('textarea#students').value;

					e.preventDefault();

					if (file) {
						file.text().then(data => processCSV(data));
					} else if (csv_text) {
						processCSV(csv_text);
					}

					function processCSV (csv_data) {
						if (csv_data.trim().substring(0,8) !== 'username') {
							csv_data = 'username,password\n' + csv_data;
						}
						Papa.parse(
							csv_data,
							{
								skipEmptyLines: true,
								header: true,
								complete: (results) => {
									let post_body = { users: results.data };

									if (collection_name) {
										post_body.collection_name = collection_name;
									}

									cloud.post(
										'/users/create_learners',
										null,
										post_body
									);
								}
							}
						);
					};
				};
				div.querySelector('button[name="bulk-create"]').addEventListener(
					'click',
					create_learners
				);
			</script>

		</div>

	</section>

	<section class="v-user__account">

		<div class="v-user__options-heading">
			<% render('frontend.views.partials.section-heading-full-width', {
				title = locale.get('title_account'),
			}) %>
		</div>

		<div class="v-user__options-contents">

			<div class="v-user__options-column">
				<div class="v-user__options-block">
					<h3 class="v-user__options-block-title"><%= locale.get('title_update_details') %></h3>
					<div class="v-user__options-block-contents">
						<form method="POST" action="/submit">
							<input type="text" name="field1" placeholder="e.mustermann@a-school-name.com">
							<input type="text" name="field2" placeholder="emustermann_teacher_332">
							<input type="text" name="field3" placeholder="********">
							<button type="submit">
								<div class="e-submit__text"><%= locale.get('b_update_details') %></div>
								<div class="e-submit__icon">
									<% render('frontend.static.svg.icon-arrow-right--24x24') %>
								</div>
							</button>
						</form>
					</div>
				</div>
			</div>

			<div class="v-user__options-column">
				<div class="v-user__options-block">
					<h3 class="v-user__options-block-title"><%= locale.get('title_delete_account') %></h3>
					<div class="v-user__options-block-contents">
						<p>
							<%= locale.get('text_automatic_account_deletion') %>
						</p>
						<div class="--buttons">
							<% render('frontend.views.partials.button', {
								label	= locale.get('b_delete_account'),
								url	 	= '#',
								color	= 'red',
								icon	= 'arrow-right',
							}) %>
						</div>
					</div>
				</div>
			</div>

		</div>

	</section>


</div>
<% end %>
