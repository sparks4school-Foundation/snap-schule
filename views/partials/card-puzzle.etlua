<article class="c-card-puzzle">

	<div class="c-card-puzzle__image">
		<img src="/static/images/puzzle-placeholder-01.png" alt="">
	</div>

	<div class="c-card-puzzle__text">
		<div class="c-card-puzzle__grade">
			<%= locale.get('nth_grade', locale.get('nth_' .. grade)) %>
		</div>
		<h3 class="c-card-puzzle__title"><%= puzzle.projectname %></h3>
	</div>

	<a href="/puzzle" class="c-card-puzzle__anchor" title="<%= puzzle_title %>"></a>

</article>
